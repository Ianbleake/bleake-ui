{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "*.tsbuildinfo"],
			"cache": true
		},
		"build:css": {
			"outputs": ["dist/**"],
			"cache": true
		},
		"check-types": {
			"dependsOn": ["^build"],
			"cache": true
		},
		"test": {
			"dependsOn": ["^build"],
			"cache": true
		},
		"lint": {
			"cache": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}