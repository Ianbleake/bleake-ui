{
	"name": "bleake-ui-monorepo",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"build": "echo 'Run bun run build in each package or use turbo' && exit 0",
		"dev": "echo 'Run bun run dev in apps/playground' && exit 0",
		"lint": "biome check --write .",
		"format": "biome format --write .",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf packages/*/dist apps/*/dist .turbo node_modules/.cache"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"tsup": "8.5.0",
		"typescript": "5.9.3",
		"turbo": "2.5.5",
		"vitest": "3.2.4"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"esbuild"
	]
}
